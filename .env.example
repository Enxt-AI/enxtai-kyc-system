# Database
# NOTE: Host port is 5433 (not default 5432) to avoid conflict with SMC project's Postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/kyc_db"

# Redis
# NOTE: Host port is 6380 (not default 6379) to avoid conflict with SMC project's Redis
REDIS_URL="redis://localhost:6380"

# MinIO
MINIO_ENDPOINT="localhost"
MINIO_PORT="9000"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_USE_SSL="false"
S3_PAN_BUCKET="pan-cards"
S3_AADHAAR_BUCKET="aadhaar-cards"
S3_LIVE_PHOTO_BUCKET="live-photos"
S3_SIGNATURES_BUCKET="signatures"

# API
JWT_SECRET="your-secret-key-change-in-production"
# NOTE: Port 5001 to avoid conflict with SMC Ticketing-Service on 3001
PORT="5001"

# KYC Session Token Secret
# Used to sign short-lived JWTs for the KYC redirect flow (client app -> EnxtAI KYC frontend).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_KYC_SESSION_SECRET="change-me-to-a-random-64-char-hex-string"

# Frontend URL (used for building kycFlowUrl in the KYC initiation response)
# NOTE: Port 5000 to avoid conflict with SMC user frontend on 3000
FRONTEND_URL="http://localhost:5000"

# Frontend
NEXT_PUBLIC_API_URL="http://localhost:5001"
