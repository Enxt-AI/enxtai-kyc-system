generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model audit_logs {
  id        String   @id
  userId    String?
  action    String
  metadata  Json?
  ipAddress String?
  userAgent String?
  timestamp DateTime @default(now())
  users     users?   @relation(fields: [userId], references: [id])

  @@index([timestamp])
  @@index([userId])
}

model client_users {
  id                 String         @id
  clientId           String?
  email              String         @unique
  password           String
  role               ClientUserRole @default(VIEWER)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime
  mustChangePassword Boolean        @default(true)
  resetToken         String?
  resetTokenExpiry   DateTime?
  clients            clients?       @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([email])
  @@index([resetToken])
}

model clients {
  id              String            @id
  name            String
  apiKey          String            @unique
  apiKeyPlaintext String?
  webhookUrl      String?
  webhookSecret   String?
  status          ClientStatus      @default(ACTIVE)
  config          Json?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  allowedDomains  Json?
  client_users    client_users[]
  kyc_submissions kyc_submissions[]
  users           users[]
  webhook_logs    webhook_logs[]

  @@index([status])
}

model digilocker_tokens {
  id           String   @id
  userId       String   @unique
  accessToken  String
  refreshToken String?
  tokenType    String   @default("Bearer")
  scope        String
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime
  users        users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([userId])
}

model kyc_submissions {
  id                    String         @id
  userId                String
  submissionDate        DateTime       @default(now())
  documentSource        DocumentSource
  panDocumentUrl        String?
  aadhaarDocumentUrl    String?
  livePhotoUrl          String?
  panNumber             String?
  aadhaarNumber         String?
  fullName              String?
  dateOfBirth           DateTime?
  address               Json?
  ocrResults            Json?
  faceMatchScore        Float?
  livenessScore         Float?
  faceExtractionSuccess Boolean        @default(false)
  cvlKraSubmitted       Boolean        @default(false)
  cvlKraSubmissionDate  DateTime?
  cvlKraResponse        Json?
  cvlKraStatus          String?
  internalStatus        InternalStatus @default(PENDING)
  finalStatus           FinalStatus    @default(INCOMPLETE)
  rejectionReason       String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime
  aadhaarBackUrl        String?
  aadhaarFrontUrl       String?
  signatureUrl          String?
  clientId              String
  clients               clients        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  users                 users          @relation(fields: [userId, clientId], references: [id, clientId], onDelete: Cascade)

  @@index([clientId])
  @@index([clientId, internalStatus])
  @@index([finalStatus])
  @@index([internalStatus])
  @@index([panNumber])
  @@index([userId])
}

model users {
  id                String             @id
  email             String
  phone             String
  kycStatus         KYCStatus          @default(PENDING)
  cvlKraId          String?            @unique
  cvlKraStatus      String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime
  clientId          String
  externalUserId    String
  audit_logs        audit_logs[]
  digilocker_tokens digilocker_tokens?
  kyc_submissions   kyc_submissions[]
  clients           clients            @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, email])
  @@unique([clientId, externalUserId])
  @@unique([clientId, phone])
  @@unique([id, clientId])
  @@index([clientId, email])
  @@index([clientId])
}

model webhook_logs {
  id             String   @id
  clientId       String
  event          String
  payload        Json
  responseStatus Int?
  responseBody   String?
  attemptCount   Int      @default(1)
  createdAt      DateTime @default(now())
  clients        clients  @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, createdAt])
  @@index([clientId])
  @@index([event])
}

enum ClientStatus {
  ACTIVE
  SUSPENDED
  TRIAL
}

enum ClientUserRole {
  ADMIN
  VIEWER
  SUPER_ADMIN
}

enum DocumentSource {
  MANUAL_UPLOAD
  DIGILOCKER
}

enum FinalStatus {
  INCOMPLETE
  COMPLETE
  REJECTED
}

enum InternalStatus {
  PENDING
  DOCUMENTS_UPLOADED
  OCR_COMPLETED
  FACE_VERIFIED
  VERIFIED
  REJECTED
  PENDING_REVIEW
}

enum KYCStatus {
  PENDING
  IN_PROGRESS
  VERIFIED
  CVL_SUBMITTED
  CVL_VALIDATED
  REJECTED
}
