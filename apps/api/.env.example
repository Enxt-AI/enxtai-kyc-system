# NOTE: Host port is 5433 (not default 5432) to avoid conflict with SMC project's Postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/kyc_db"
# NOTE: Host port is 6380 (not default 6379) to avoid conflict with SMC project's Redis
REDIS_URL="redis://localhost:6380"
S3_ENDPOINT="localhost"
S3_PORT="9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_USE_SSL="false"
S3_PAN_BUCKET="pan-cards"
S3_AADHAAR_BUCKET="aadhaar-cards"
S3_LIVE_PHOTO_BUCKET="live-photos"
S3_SIGNATURES_BUCKET="signatures"
JWT_SECRET="your-secret-key-change-in-production"
# NOTE: Port 5001 to avoid conflict with SMC Ticketing-Service on 3001
PORT="5001"

# KYC Session Token Secret
# Used to sign short-lived JWTs for the KYC redirect flow (client app -> EnxtAI KYC frontend).
# Must match the same value in the web app's environment for token validation.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_KYC_SESSION_SECRET="change-me-to-a-random-64-char-hex-string"

# Frontend URL (used for building kycFlowUrl in KYC initiation response)
# In production, set to the Vercel deployment URL (e.g., https://enxtai-kyc-system-web.vercel.app)
# NOTE: Port 5000 to avoid conflict with SMC user frontend on 3000
FRONTEND_URL="http://localhost:5000"
FACE_API_MODELS_PATH="./node_modules/@vladmandic/face-api/model"
FACE_API_MODEL_TYPE="ssdMobilenetv1"

# DigiLocker API Configuration (via API Setu)
DIGILOCKER_CLIENT_ID="your-digilocker-client-id"
DIGILOCKER_CLIENT_SECRET="your-digilocker-client-secret"
DIGILOCKER_REDIRECT_URI="https://your-domain.ngrok-free.app/api/digilocker/auth/callback"
DIGILOCKER_AUTHORIZE_URL="https://digilocker.meripehchaan.gov.in/public/oauth2/1/authorize"
DIGILOCKER_TOKEN_URL="https://api.digitallocker.gov.in/public/oauth2/1/token"
DIGILOCKER_DOCUMENTS_URL="https://digilocker.meripehchaan.gov.in/public/oauth2/1"

# IMPORTANT: Scope must match API Setu console checkboxes
# Working configuration (tested 2026-01-16):
# - For document access: DIGILOCKER_SCOPE="issued drive"
# - For OpenID only: DIGILOCKER_SCOPE="openid" (NOTE: Causes token exchange error)
# - Empty scope: DIGILOCKER_SCOPE="" (uses API defaults)
DIGILOCKER_SCOPE="issued drive"

# PKCE Configuration:
# - PKCE is enabled by default for security (DIGILOCKER_ENABLE_PKCE=true)
# - If DigiLocker rejects PKCE, set DIGILOCKER_ENABLE_PKCE=false
# - PKCE provides additional security for OAuth flows
DIGILOCKER_ENABLE_PKCE="true"
