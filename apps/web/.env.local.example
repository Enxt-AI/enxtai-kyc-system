NEXT_PUBLIC_API_URL="http://localhost:5001"

# KYC Session Token Secret
# Must match the API server's JWT_KYC_SESSION_SECRET value.
# Used by the /api/kyc/validate-token route to verify session JWTs.
JWT_KYC_SESSION_SECRET="change-me-to-a-random-64-char-hex-string"

# DigiLocker OAuth Callback URL (must match API Setu configuration)
NEXT_PUBLIC_DIGILOCKER_CALLBACK_URL=http://localhost:5000/kyc/digilocker
